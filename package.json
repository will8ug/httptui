{
  "name": "httptui",
  "version": "0.0.1",
  "description": "Interactive TUI for sending HTTP requests from .http files",
  "type": "module",
  "bin": {
    "httptui": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'test/**/*.ts'"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "http",
    "rest",
    "tui",
    "terminal",
    "cli",
    "api",
    "rest-client"
  ],
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.0.0",
    "react": "^19.0.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
