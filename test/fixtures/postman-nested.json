{
  "info": {
    "name": "Nested Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.example.com/users",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["users"]
            },
            "header": []
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "https://api.example.com/users",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["users"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "admin" },
                { "key": "password", "value": "secret" }
              ]
            },
            "method": "POST",
            "url": {
              "raw": "https://api.example.com/login",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["login"]
            },
            "header": []
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "abc123token" }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "https://api.example.com/profile",
              "protocol": "https",
              "host": ["api", "example", "com"],
              "path": ["profile"]
            },
            "header": []
          }
        }
      ]
    },
    {
      "name": "Deeply Nested",
      "item": [
        {
          "name": "Subfolder",
          "item": [
            {
              "name": "Deep Request",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "https://api.example.com/deep",
                  "protocol": "https",
                  "host": ["api", "example", "com"],
                  "path": ["deep"]
                },
                "header": []
              }
            }
          ]
        }
      ]
    }
  ]
}
